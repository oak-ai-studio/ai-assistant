# Database
DATABASE_URL="postgresql://assistant:dev_password@localhost:5432/ai_assistant"

# LLM
LLM_PROVIDER="openai"
# LLM_BASE_URL="https://openrouter.ai/api/v1"  # Optional: custom LLM provider base URL (OpenAI/Anthropic compatible)
OPENAI_MODEL="gpt-4.1-mini"  # Optional: override default model
ANTHROPIC_MODEL="claude-3-5-haiku-20241022"  # Optional: Anthropic provider model name
# MEMORY_RECALL_ENABLED="true"
# MEMORY_RECALL_MAX_ITEMS="5"
# MEMORY_RECALL_MIN_CONFIDENCE="0.7"
# MEMORY_DEBUG_LOGS="true"
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
JWT_SECRET="replace-with-a-long-random-secret"
LLM_BASE_URL=""

# Anthropic (Claude) example
# LLM_PROVIDER="anthropic"
# ANTHROPIC_API_KEY="sk-ant-..."

# Anthropic compatible endpoint (e.g. AWS Bedrock Claude)
# LLM_PROVIDER="anthropic"
# ANTHROPIC_API_KEY="..."
# LLM_BASE_URL="https://bedrock-runtime.us-east-1.amazonaws.com"

# Server
PORT=3000
NODE_ENV="development"
